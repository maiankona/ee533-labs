#!/bin/bash

# CUDA → PTX
# fmad removes fused MAC, O0 removes optimization, arch ensures bf16 support
nvcc -O0 -ptx -arch=sm_80 --fmad=false $1.cu -o $1.ptx

# Convert PTX → custom ISA
python3 ptx2custom.py $1.ptx

echo "Generated files:"
echo "  $1.ptx        - PTX assembly"
echo "  $1_custom.txt - Our custom GPU ISA"

